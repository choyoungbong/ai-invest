# AI INVEST 환경 변수
DATABASE_URL=postgresql+asyncpg://aiinvest:aiinvest@postgres:5432/aiinvest
REDIS_URL=redis://redis:6379/0

# 텔레그램 알림 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Claude AI 분석 (선택 – https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=

# 한국투자증권 오픈 API (Phase 5)
# https://apiportal.koreainvestment.com 에서 앱 등록 후 발급
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=12345678-01    # 계좌번호 (앞8자리-뒤2자리)
KIS_MOCK=true                  # true=모의투자, false=실전투자

# 자금 배분 설정 (I)
TOTAL_BUDGET=5000000       # 총 투자 예산 (원)
ALLOC_BREAKOUT=0.40        # 돌파매매 40%
ALLOC_MA_CROSS=0.30        # MA 크로스 30%
ALLOC_RSI_REVERSAL=0.20    # RSI 반등 20%
ALLOC_MACD=0.10            # MACD 10%
MAX_SINGLE_TRADE_PCT=0.20  # 전략 예산 중 1회 최대 비율
